# ══════════════════════════════════════════════════════════════════════
# ConcurShield — 环境变量配置
#
# 快速启动（不需要任何 API Key）：
#   cp .env.example .env
#   uvicorn backend.main:app --reload --port 8000
#   → 默认 MockLLM 模式，全本地，不调用任何外部服务
# ══════════════════════════════════════════════════════════════════════

# ── LLM 模式 ──────────────────────────────────────────────────────────
#
# 默认：MockLLM（规则脚本）
#   无需设置任何变量。所有 Agent 行为由关键词规则模拟，完全可预期，
#   支持完整 eval 测试套件（pytest backend/tests/ -v）。
#
# 切换到 GPT-4o（真实 AI）：
#   1. 填写 OPENAI_API_KEY
#   2. 设置 AGENT_USE_REAL_LLM=1
#   效果：
#   → Agent 决策由 GPT-4o 真实推理（不再是规则脚本）
#   → 发票 OCR 自动调用 GPT-4o Vision 识别真实图片
#   → 解锁"用户改字段"Agent 行为（"把金额改成 380"等自然语言指令）
#
OPENAI_API_KEY=              # GPT-4o Agent + Vision OCR（可选）
OPENAI_MODEL=gpt-4o          # 可选：gpt-4o / gpt-4o-mini / gpt-4-turbo
AGENT_USE_REAL_LLM=          # 设为 "1" 启用 GPT-4o（需要上面的 Key）
ANTHROPIC_API_KEY=           # 预留：Anthropic Claude 接口（暂未启用）

# ── 认证（双模式）─────────────────────────────────────────────────────
#
# mock 模式（默认开发用）：
#   请求头 X-User-Id / X-User-Role 决定身份
#   浏览器端用导航栏下拉框或 URL 参数 ?as=manager 切换角色
#
# clerk 模式（生产用）：
#   前端加载 Clerk SDK，后端验证 JWT
#
AUTH_MODE=mock               # mock（开发）| clerk（生产）
CLERK_SECRET_KEY=            # AUTH_MODE=clerk 时必填
CLERK_PUBLISHABLE_KEY=       # AUTH_MODE=clerk 时必填（前端用）

# ── 数据库 ────────────────────────────────────────────────────────────
#
# 本地开发：留空，自动使用 SQLite（./concurshield.db）
# 生产：postgresql+asyncpg://user:pass@host:5432/dbname
#
DATABASE_URL=                # 留空 = SQLite 本地文件（./concurshield.db）

# ── Eval 数据库（物理隔离）────────────────────────────────────────────
#
# LLM traces + Eval runs 存入独立数据库，与业务数据（submissions / drafts）
# 物理隔离。好处：
#   1. Eval 数据量增长（每次 LLM 调用都写 trace）不影响主库性能
#   2. 可以独立备份 / 清理 eval 历史
#   3. 将来可以把 Eval 库切到单独的 Postgres 实例
#
# 留空时默认 sqlite+aiosqlite:///./concurshield_eval.db（同目录独立 SQLite）
# 生产推荐：postgresql+asyncpg://user:pass@host:5432/concurshield_eval
#
# 老项目升级：先启动一次服务自动建表，然后跑迁移脚本把历史数据搬过去：
#   python scripts/migrate_eval_data.py
#
EVAL_DATABASE_URL=           # 留空 = SQLite 本地文件（./concurshield_eval.db）

# ── 文件存储（双模式）────────────────────────────────────────────────
#
# local 模式（默认）：上传文件保存到 UPLOAD_DIR
# r2 模式：上传到 Cloudflare R2（生产推荐）
#
STORAGE_BACKEND=local        # local（开发）| r2（生产）
UPLOAD_DIR=./uploads         # STORAGE_BACKEND=local 时使用

R2_BUCKET=                   # STORAGE_BACKEND=r2 时使用
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
